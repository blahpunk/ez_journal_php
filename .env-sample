# Copy this file to .env and fill in real values.
# Example: cp .env-sample .env

# SQLite DSN (absolute path recommended)
DATABASE_URL=sqlite:///.data/journal.db

# Application secrets
SECRET_KEY=replace-with-random-secret
SECURE_AUTH_SECRET=replace-with-shared-cookie-hmac-secret
# Optional: comma-separated previous SECURE_AUTH_SECRET values during key rotation
SECURE_AUTH_PREVIOUS_SECRETS=
# Optional legacy alias if SECURE_AUTH_SECRET is unset
FLASK_SECRET_KEY=

# External OAuth integration endpoints
OAUTH_LOGIN_URL=https://secure.example.com/oauth_login
OAUTH_LOGOUT_URL=https://secure.example.com/logout

# Canonical OAuth users
JOURNAL_ADMIN_EMAIL=admin@example.com

# Fallback PIN account when OAuth is unavailable
JOURNAL_FALLBACK_ADMIN_LABEL=Fallback Admin
JOURNAL_FALLBACK_ADMIN_PIN=change-me
JOURNAL_FALLBACK_ADMIN_IS_EDITOR=true

# Backward-compatible alias (used if JOURNAL_FALLBACK_ADMIN_LABEL is not set)
# JOURNAL_PIN_LABEL=Fallback Admin
# Backward-compatible alias (used if JOURNAL_FALLBACK_ADMIN_PIN is not set)
# PIN_USER_PIN=change-me

# Runtime
LOG_PATH=.logs/journal.log
JOURNAL_TIMEZONE=America/Chicago
# Optional backward-compatible alias for timezone
APP_TIMEZONE=
ADMIN_SESSION_TTL_SECONDS=315360000
